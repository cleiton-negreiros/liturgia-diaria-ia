{
  "buildCommand": "npm run build:web",
  "outputDirectory": "web-build",
  "env": {
    "EXPO_USE_METRO_WORKSPACE_ROOT": "1"
  },
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
